{
  "app": "python3 app.py",
  "context": {
    "account":          "YOUR_ACCOUNT_ID",
    "region":           "us-east-1",
    "github_owner":     "YOUR_GITHUB_USERNAME",
    "github_repo":      "ab-testing-gateway",
    "github_branch":    "main",
    "connection_arn":   "arn:aws:codeconnections:us-east-1:YOUR_ACCOUNT_ID:connection/YOUR_CONNECTION_ID",
    "model_groups": [
      "VariantA-BERT-FP32-ModelGroup",
      "VariantB-BERT-INT8-ModelGroup",
      "VariantC-DistilBERT-ModelGroup"
    ],
    "canary_weight":         0.10,
    "canary_wait_minutes":   15,
    "error_rate_threshold":  0.05,
    "p95_latency_threshold": 5000,
    "routing_table":         "ab-gateway-routing-config",
    "emf_namespace":         "ABGateway"
  }
}
